# Copy to .env (do not commit .env).

ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# Chat
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_TEMPERATURE=0.2

# Text-to-speech — OpenAI (/api/tts), optional overrides:
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=nova

# ElevenLabs (/api/tts-elevenlabs) — set ELEVENLABS_API_KEY to enable Engine → ElevenLabs in the UI
# ELEVENLABS_API_KEY=
# Default voice if the Voice ID field is left empty (paste from app → Voices):
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# PORT=8787
